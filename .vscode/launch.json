{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Playwright: Debug E2E (e2e.spec.ts)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": ["test", "tests/e2e.spec.ts", "--project=chromium", "--headed"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },

  ]
}
